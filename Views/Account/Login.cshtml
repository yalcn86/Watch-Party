@model WhatchParty.Models.User

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IKARUS // UPLINK_LOGIN</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-main: #0a0a0f;
            --bg-card: #12121a;
            --cyber-cyan: #00f0ff;
            --cyber-yellow: #ffec00;
            --cyber-red: #ff0055;
            --text-main: #f1f5f9;
            --text-muted: #64748b;
            --border-color: #222235;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: 'Rajdhani', sans-serif;
            background-image: radial-gradient(circle at 50% 50%, #141425 0%, #0a0a0f 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-frame {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-top: 4px solid var(--cyber-cyan);
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 15px 35px rgba(0, 240, 255, 0.05);
            position: relative;
        }

        .login-frame::before {
            content: '//';
            position: absolute;
            top: 15px;
            right: 20px;
            color: var(--text-muted);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
        }

        .title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            letter-spacing: 2px;
            margin-bottom: 5px;
            text-shadow: 0 0 10px var(--cyber-cyan);
        }

        .subtitle {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 30px;
            text-transform: uppercase;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            color: var(--cyber-cyan);
            margin-bottom: 8px;
            letter-spacing: 1px;
        }

        .form-group input {
            width: 100%;
            background: var(--bg-main);
            border: 1px solid var(--border-color);
            padding: 12px 15px;
            color: #fff;
            font-family: monospace;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--cyber-cyan);
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.2);
        }

        .cyber-btn {
            width: 100%;
            padding: 15px;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            background: var(--cyber-cyan);
            color: #000;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .cyber-btn:hover {
            background: #fff;
            box-shadow: 0 0 15px var(--cyber-cyan);
        }

        .alert-error {
            background: rgba(255, 0, 85, 0.1);
            border: 1px solid var(--cyber-red);
            color: var(--cyber-red);
            padding: 12px;
            font-size: 0.9rem;
            margin-bottom: 20px;
            font-family: monospace;
        }

        .redirect-link {
            text-align: center;
            margin-top: 25px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .redirect-link a {
            color: var(--cyber-yellow);
            text-decoration: none;
            font-weight: bold;
        }

        .redirect-link a:hover {
            text-shadow: 0 0 8px var(--cyber-yellow);
        }
    </style>
</head>
<body>

    <div class="login-frame">
        <h1 class="title">SECURE_ACCESS</h1>
        <p class="subtitle">IKARUS HUB tüneline bağlanın</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">> ERROR: @ViewBag.Error</div>
        }

        <form action="/Account/Login" method="POST">
            <div class="form-group">
                <label>CORE_USERNAME</label>
                <input type="text" name="username" required placeholder="Kullanıcı adınızı girin...">
            </div>

            <div class="form-group">
                <label>CRYPT_PASSWORD</label>
                <input type="password" name="password" required placeholder="******">
            </div>

            <button type="submit" class="cyber-btn">ESTABLISH UPLINK</button>
        </form>

        <div class="redirect-link">
            Sistemde kaydınız yok mu? <a href="/Account/Register">CREATE ACCOUNT</a>
        </div>
    </div>

</body>
</html>